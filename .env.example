# ── Backend ──────────────────────────────────────────────────────────────
# Port the NestJS API listens on
PORT=3000

# Postgres + pgvector connection (used once RAG is wired up; the heuristic
# analyzer runs fine without it).
DATABASE_URL=postgresql://scamba:scamba@localhost:5432/scamba

# Anthropic / Claude. Leave BLANK to run the offline heuristic analyzer.
# Set it to enable the Claude-powered analyzer + embeddings-based retrieval.
ANTHROPIC_API_KEY=
# Model used for scam analysis (see CLAUDE.md "AI / analysis pipeline").
# Defaults to claude-opus-4-8; set claude-sonnet-4-6 or claude-haiku-4-5 to trade
# some quality for lower cost/latency on this per-request classification.
ANTHROPIC_MODEL=claude-opus-4-8

# ── Frontend ─────────────────────────────────────────────────────────────
# Base URL the React app calls. In dev, Vite proxies /api to the backend,
# so this can stay empty locally.
VITE_API_BASE_URL=
